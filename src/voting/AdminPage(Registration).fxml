<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="voting.Controller">
   <center>
      <AnchorPane prefHeight="560.0" prefWidth="660.0">
         <children>
            <Label alignment="CENTER" layoutX="136.0" layoutY="43.0" prefHeight="40.0" prefWidth="359.0" text="Candidate Registration" textAlignment="RIGHT" textFill="#102c57">
               <font>
                  <Font name="Serif Bold" size="30.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="107.0" layoutY="112.0" text="Name" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <TextField fx:id="firstnameinput" layoutX="106.0" layoutY="133.0" prefHeight="25.0" prefWidth="190.0" promptText="First Name">
               <font>
                  <Font name="Serif Regular" size="12.0" />
               </font>
            </TextField>
            <TextField fx:id="emailinput" layoutX="107.0" layoutY="333.0" prefHeight="25.0" prefWidth="190.0" promptText="Enter Phone or Email" />
            <RadioButton fx:id="maleradio" layoutX="389.0" layoutY="309.0" mnemonicParsing="false" opacity="0.81" prefHeight="15.0" prefWidth="55.0" selected="true" text="Male" textFill="#102c57">
               <toggleGroup>
                  <ToggleGroup fx:id="gender" />
               </toggleGroup>
            </RadioButton>
            <RadioButton fx:id="femaleradio" layoutX="390.0" layoutY="330.0" mnemonicParsing="false" opacity="0.81" text="Female" textFill="#102c57" toggleGroup="$gender" />
            <RadioButton fx:id="otherradio" layoutX="391.0" layoutY="352.0" mnemonicParsing="false" opacity="0.81" text="Others" textFill="#102c57" toggleGroup="$gender" />
            <Label layoutX="387.0" layoutY="283.0" text="Gender" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <TextField fx:id="lastnameinput" layoutX="381.0" layoutY="133.0" prefHeight="25.0" prefWidth="190.0" promptText="Last Name">
               <font>
                  <Font name="Serif Regular" size="12.0" />
               </font>
            </TextField>
            <Label alignment="CENTER" layoutX="108.0" layoutY="312.0" text="Email / Phone" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <Button fx:id="submitbutton" layoutX="285.0" layoutY="468.0" mnemonicParsing="false" onAction="#SwitchToAdminRegSuccessOrUnsuccess" prefHeight="33.0" prefWidth="110.0" style="-fx-background-color: rgb(16,44,87);" text="Submit" textFill="WHITE">
               <font>
                  <Font name="Serif Bold" size="20.0" />
               </font>
            </Button>
            <!--<FontAwesomeIcon iconName="HOME" />-->
            <TextField fx:id="passwordinput" layoutX="107.0" layoutY="400.0" prefHeight="25.0" prefWidth="190.0" promptText="Enter Password" />
            <Label alignment="CENTER" layoutX="108.0" layoutY="379.0" text="Password" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <TextField fx:id="cnicinput" layoutX="107.0" layoutY="201.0" prefHeight="25.0" prefWidth="190.0" promptText="Enter Cnic" />
            <Label alignment="CENTER" layoutX="108.0" layoutY="180.0" text="CNIC" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <TextField fx:id="familyinput" layoutX="107.0" layoutY="267.0" prefHeight="25.0" prefWidth="190.0" promptText="Enter Family" />
            <Label alignment="CENTER" layoutX="108.0" layoutY="246.0" text="Family No" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <Label layoutX="242.0" layoutY="357.0" opacity="0.71" prefHeight="17.0" prefWidth="62.0" text="(Optional)" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="13.0" />
               </font>
            </Label>
            <ComboBox fx:id="citycombo" layoutX="386.0" layoutY="204.0" onMouseEntered="#set_CityRegistration_ChoiceBox" prefHeight="25.0" prefWidth="174.0" promptText="...." />
            <Label alignment="CENTER" layoutX="382.0" layoutY="180.0" prefHeight="20.0" prefWidth="138.0" text="Select Constituency" textFill="#102c57">
               <font>
                  <Font name="Serif Regular" size="16.0" />
               </font>
            </Label>
            <Line endX="168.0" layoutX="285.0" layoutY="82.0" startX="-100.0" stroke="#102c57" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="159.0" layoutY="126.0" size="1.5em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="521.0" layoutY="197.0" size="1.5em" text="" wrappingWidth="21.72857093811035" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="442.0" layoutY="300.0" size="1.5em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="209.0" layoutY="327.0" size="1.4em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="152.0" layoutY="196.0" size="1.5em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="187.0" layoutY="262.0" size="1.5em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="181.0" layoutY="394.0" size="1.4em" text="" />
            <FontAwesomeIcon fill="#c5001a" fontSmoothingType="LCD" glyphName="USER" layoutX="270.0" layoutY="418.0" size="1.4em" text="" />
         </children>
      </AnchorPane>
   </center>
   <left>
      <VBox prefHeight="200.0" prefWidth="170.0" BorderPane.alignment="CENTER">
         <children>
            <AnchorPane fx:id="menu" prefHeight="560.0" prefWidth="152.0" style="-fx-background-color: rgb(16,44,87);">
               <children>
                  <Label fx:id="menulabel" alignment="CENTER" layoutY="-3.0" prefHeight="77.0" prefWidth="170.0" style="-fx-background-color: rgb(44, 78, 128);" text="Panels" textAlignment="CENTER" textFill="WHITE">
                     <font>
                        <Font name="Serif Bold" size="28.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
         </children>
      </VBox>
   </left>
   <right>
      <AnchorPane fx:id="menu1" prefHeight="400.0" prefWidth="170.0" style="-fx-background-color: rgb(16,44,87);" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="menulabel1" alignment="CENTER" layoutY="-3.0" prefHeight="77.0" prefWidth="170.0" style="-fx-background-color: rgb(44, 78, 128);" text="Overview" textAlignment="CENTER" textFill="WHITE">
               <font>
                  <Font name="Serif Bold" size="28.0" />
               </font>
            </Label>
            <Label alignment="CENTER" layoutX="1.0" layoutY="199.0" prefHeight="28.0" prefWidth="169.0" style="-fx-background-color: rgb(44, 78, 128);" text=" Admin " textFill="WHITE">
               <font>
                  <Font name="Serif Bold" size="24.0" />
               </font>
            </Label>
            <FontAwesomeIcon fx:id="AuthorNameIcon" fill="WHITE" glyphName="USER" layoutX="56.0" layoutY="173.0" size="5em" text="" wrappingWidth="28.977611541748047">
               <font>
                  <Font size="19.0" />
